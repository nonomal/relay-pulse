# ============================================
# RelayPulse PostgreSQL 环境配置模板
# ============================================
# 生产环境：
#   1. cp .env.pg.example .env
#   2. 修改密码为强密码
#   3. docker compose -f docker-compose.pg.yaml up -d
#
# 本地开发：
#   1. make pg-up && make dev-pg（自动覆盖 HOST/PORT 为本地值）
#   2. API Keys 未配置，探测功能会返回认证错误（预期行为）
#   3. 如需测试真实 API：make dev-pg-prod（会加载 .env 中的生产 Keys）

# 时区设置
TZ=Asia/Shanghai

# Gin 运行模式
GIN_MODE=release

# ============================================
# PostgreSQL 数据库配置
# ============================================
# ⚠️ 重要：修改密码后，POSTGRES_PASSWORD 和 MONITOR_POSTGRES_PASSWORD 必须保持一致
POSTGRES_USER=relaypulse
POSTGRES_PASSWORD=change_me_to_strong_password
POSTGRES_DB=relaypulse

# ============================================
# 存储配置（PostgreSQL）
# ============================================
MONITOR_STORAGE_TYPE=postgres

# PostgreSQL 连接信息
# Docker 生产默认值（容器内网络）
# 本地开发时由 Makefile 自动覆盖为 localhost:5433
MONITOR_POSTGRES_HOST=postgres
MONITOR_POSTGRES_PORT=5432
MONITOR_POSTGRES_USER=${POSTGRES_USER}
MONITOR_POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
MONITOR_POSTGRES_DATABASE=${POSTGRES_DB}
MONITOR_POSTGRES_SSLMODE=disable

# PostgreSQL 连接池配置
MONITOR_POSTGRES_MAX_OPEN_CONNS=25
MONITOR_POSTGRES_MAX_IDLE_CONNS=5
MONITOR_POSTGRES_CONN_MAX_LIFETIME=1h

# ============================================
# 可选配置
# ============================================
# CORS 配置（开发环境）
# MONITOR_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
