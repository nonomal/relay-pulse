interval: "1m"       # 巡检间隔，可写成 "30s"、"1m"、"5m" 等
slow_latency: "5s"   # 慢请求阈值，超过则从绿降为黄

# 按服务类型覆盖慢请求阈值（可选）
# key 不区分大小写，未配置的服务使用全局 slow_latency
# slow_latency_by_service:
#   cc: "15s"    # Claude Code 对速度要求较低
#   cx: "10s"    # Codex
#   gm: "3s"     # 模型 API 要求更快

# ============================================
# 重试配置
# ============================================
# 探测失败时自动重试，适用于网络不稳定场景
# 重试条件：所有 status=0 的错误（除超时外）
# 超时（context.DeadlineExceeded）不重试，因为已达总超时限制

# 全局重试次数（默认 0，不重试；表示"额外重试次数"，不含首次）
# retry: 0

# 退避基准间隔（默认 200ms）
# retry_base_delay: "200ms"

# 退避最大间隔（默认 2s）
# retry_max_delay: "2s"

# 抖动比例（0-1，默认 0.2；0 表示无抖动）
# retry_jitter: 0.2

# 按服务类型覆盖重试配置（可选）
# retry_by_service:
#   cc: 2        # Claude Code 服务额外重试 2 次
#   gm: 1        # Gemini 服务额外重试 1 次

# retry_base_delay_by_service:
#   cc: "300ms"

# retry_max_delay_by_service:
#   cc: "3s"

# retry_jitter_by_service:
#   cc: 0.1

# ============================================
# 并发控制与调度策略
# ============================================

# 最大并发探测数（可选，默认 10）
# - 不配置或 0: 使用默认值 10
# - -1: 无限制，自动扩容到监测项数量
# - >0: 硬上限，超过时监测项会排队等待执行
# 建议：根据监测项数量和服务器性能调整
#   - 小规模（<20项）: 10-20
#   - 中等规模（20-100项）: 50-100
#   - 大规模（>100项）: -1 或更高值
max_concurrency: 15

# 错峰调度（可选，默认 true）
# 开启后会将监测项在巡检周期内均匀分散，避免流量突发
# - true: 启用错峰（推荐）
# - false: 所有监测项同时执行（仅用于调试）
stagger_probes: true

# ============================================
# API 性能优化
# ============================================

# 并发查询优化（可选，默认 false）
# 启用后 /api/status 接口会使用 goroutine 并发查询多个监测项
# ⚠️ 仅适用于 PostgreSQL，SQLite 使用单连接无并发收益
# 性能提升：10 个监测项查询时间从 ~2s 降至 ~300ms（-85%）
enable_concurrent_query: false

# 并发查询限制（可选，默认 10，仅当 enable_concurrent_query=true 时生效）
# 限制同时执行的数据库查询数量，防止连接池耗尽
# 建议：根据数据库连接池大小调整
#   - max_open_conns >= concurrent_query_limit × 并发请求数 × 1.2
#   - 示例：50 >= 10 × 3 × 1.2 = 36（安全）
concurrent_query_limit: 10

# 可用率中黄色状态的权重（0-1，默认 0.7）
# 绿色=1.0, 黄色=degraded_weight, 红色=0.0
# 可选配置，不设置则使用默认值 0.7
degraded_weight: 0.7

# ============================================
# 赞助商置顶配置
# ============================================
# 用于在页面初始加载时置顶符合条件的赞助商监测项
# 用户点击任意排序按钮后置顶失效，刷新页面恢复
sponsor_pin:
  enabled: true           # 是否启用置顶功能（默认 true）
  max_pinned: 3           # 最多置顶数量（默认 3）
  min_uptime: 95.0        # 最低可用率要求（默认 95%）
  min_level: "beacon"     # 最低赞助级别：public/signal/pulse/beacon/backbone/core（默认 beacon）

# ============================================
# 热板/冷板功能配置
# ============================================
# 用于将监测项分为"热板"（正常监测）和"冷板"（暂停监测，仅展示历史数据）
# 适用场景：
#   - 服务商质量长期波动，移入冷板保留历史供对比
#   - 渠道/节点下线，停止监测避免误报，保留审计数据
#   - 监测项规模增长，低价值项入冷板降低 API 调用量
boards:
  enabled: false          # 是否启用热板/冷板功能（默认 false）
# 监测项中配置 board 字段：
#   board: "hot"          # 热板（默认），正常监测，实时更新数据
#   board: "cold"         # 冷板，停止监测，仅展示历史数据
#   cold_reason: "..."    # 可选：移入冷板的原因（仅 board=cold 时有效）
# 与现有机制的关系：
#   | 状态             | 探测 | 存储 | 展示 | 用途                   |
#   | disabled=true    | ❌   | ❌   | ❌   | 彻底禁用               |
#   | hidden=true      | ✅   | ✅   | ❌   | 临时隐藏但继续监测     |
#   | board=cold       | ❌   | ❌   | ✅   | 展示历史但不探测       |

# ============================================
# 自助测试功能配置
# ============================================
# 允许用户通过 Web 界面测试自己的 API 端点
# ⚠️ 注意：默认关闭，启用前请评估安全风险
selftest:
  enabled: false                 # 是否启用自助测试功能（默认 false）
  max_concurrent: 10             # 最大并发测试数（默认 10）
  max_queue_size: 50             # 最大排队数量（默认 50）
  job_timeout: "30s"             # 单个测试超时时间（默认 30s）
  result_ttl: "2m"               # 测试结果保留时间（默认 2m）
  rate_limit_per_minute: 10      # IP 速率限制：每分钟最多测试次数（默认 10）
  # 安全机制：
  # - 仅支持 HTTPS 协议
  # - 必须使用域名（不支持 IP 地址）
  # - 自动检测并阻止内网 IP（10.x, 172.16.x, 192.168.x, 127.x 等）
  # - API 密钥仅用于测试，不会被存储或记录
  # - 基于 Token Bucket 的 IP 级速率限制

# ============================================
# 事件通知配置（状态订阅）
# ============================================
# 用于订阅服务状态变更事件
# 外部系统（如 Cloudflare Worker）可轮询 /api/events 获取事件
# 然后触发通知（如 Telegram 消息）
events:
  enabled: false          # 是否启用事件功能（默认 false）
  down_threshold: 2       # 连续 N 次不可用触发 DOWN 事件（默认 2）
  up_threshold: 1         # 连续 N 次可用触发 UP 事件（默认 1）
  api_token: ""           # API 访问令牌（空=无鉴权，建议生产环境配置）
  # API 端点：
  # - GET /api/events?since_id=0&limit=100  获取事件列表
  # - GET /api/events/latest                获取最新事件ID
  # 状态映射：绿色/黄色 → 可用，红色 → 不可用

# ============================================
# 存储配置（支持 SQLite 和 PostgreSQL）
# ============================================
storage:
  type: "sqlite"  # 存储类型："sqlite" 或 "postgres"

  # SQLite 配置（单机部署推荐）
  sqlite:
    path: "monitor.db"  # 数据库文件路径

  # PostgreSQL 配置（K8s/多副本部署推荐）
  # 取消注释以下配置以启用 PostgreSQL
  # postgres:
  #   host: "localhost"
  #   port: 5432
  #   user: "monitor"
  #   password: "monitor_password"  # 建议使用环境变量 MONITOR_POSTGRES_PASSWORD
  #   database: "llm_monitor"
  #   sslmode: "disable"  # 生产环境建议使用 "require"
  #   max_open_conns: 25
  #   max_idle_conns: 5
  #   conn_max_lifetime: "1h"

# ============================================
# 临时下架配置（隐藏但继续监测）
# ============================================
# 用于临时下架服务商（如商家不配合整改）
# 下架后：
#   - 调度器继续探测，存储结果（用于整改证据）
#   - API 默认不返回（可加 ?include_hidden=true 调试）
#   - 前端不展示
#   - sitemap 不包含

# 批量下架整个服务商（provider 级别）
# hidden_providers:
#   - provider: "问题商家A"
#     reason: "服务质量不达标，待整改"
#   - provider: "问题商家B"
#     reason: "API 频繁超时，沟通整改中"

# 风险服务商配置（provider 级别）
# 用于标记存在风险的服务商，风险徽标会自动显示在该服务商的所有监测项上
# risk_providers:
#   - provider: "风险商家A"
#     risks:
#       - label: "跑路风险"                # 必填：简短标签（黄色警告三角）
#         discussion_url: "https://forum.example.com/topic/123"  # 可选：讨论页面链接
#   - provider: "风险商家B"
#     risks:
#       - label: "服务不稳定"

# ============================================
# 通用徽标系统配置
# ============================================
# 用于在监测项上显示各类信息徽标（API Key 来源、功能特性等）
# 徽标颜色和图标由 kind + variant 决定，前端通过 i18n 显示翻译文本

# 是否启用徽标系统（默认 false）
# 开启后会显示 API Key 来源、监测频率等徽标
# 未配置任何徽标时，默认显示"官方 API Key"徽标
enable_badges: true

# 全局徽标定义（badge_definitions）
# 定义所有可复用的徽标，在 badge_providers 或 monitors.badges 中通过 id 引用
badge_definitions:
  # API Key 来源类徽标
  api_key_user:
    kind: "source"       # 类型：source(来源)/info(信息)/feature(功能特性)
    variant: "info"      # 样式：default(灰)/success(绿)/warning(黄)/danger(红)/info(蓝)
    weight: 50           # 排序权重，数值越大越靠前（默认 0）
  api_key_official:
    kind: "source"
    variant: "success"   # 绿色徽标，表示官方 API
    weight: 80           # 官方 API 排在用户提交之前
  # 功能特性类徽标
  stream_support:
    kind: "feature"
    variant: "success"
    weight: 50
    url: "https://docs.example.com/streaming"  # 可选：点击跳转链接

# Provider 级别徽标注入（badge_providers）
# 为同一服务商的所有监测项自动注入指定徽标
badge_providers:
  - provider: "88code"
    badges:
      - "api_key_official"   # 简写形式：直接引用已定义的徽标 id
  - provider: "duckcoding"
    badges:
      - id: "api_key_user"   # 对象形式：可覆盖 tooltip
        tooltip_override: "用户 @example 提供的 API Key，欢迎申请收录"

# ============================================
# 监测任务配置
# ============================================
monitors:
  # --- 88code ---
  - provider: "88code"
    provider_slug: "88code"  # 可选：URL slug（用于生成服务商专属页面链接 /p/88code），未配置时使用 provider 小写
    provider_url: "https://88code.com"  # 可选：服务商官网链接，前端可点击跳转
    service: "cc"
    category: "commercial"  # 必填：商业站(commercial) 或 公益站(public)
    sponsor: "团队自有"      # 必填：提供 API Key 的赞助者
    sponsor_url: "https://example.com/sponsor"  # 可选：赞助者链接
    sponsor_level: "beacon"        # 可选：赞助等级 public/signal/pulse/beacon(🔺)/backbone(⬢)/core(💠)
    channel: "vip-channel"  # 业务通道标识（可选），用于分类和过滤
    url: "https://api.88code.com/v1/chat/completions"
    method: "POST"
    api_key: "sk-xxxxxxxx"  # 可通过环境变量覆盖，优先级见下方 env_var_name 说明
    # env_var_name: "MONITOR_88CODE_CC_CUSTOM_API_KEY"  # 可选：自定义环境变量名
    # 使用场景：1) 中文 channel 如 "cx专用" 自动生成的变量名不清晰
    #          2) 解决同 provider 多个相似 channel 的命名冲突
    # 优先级：env_var_name（最高）> MONITOR_<PROVIDER>_<SERVICE>_<CHANNEL>_API_KEY > MONITOR_<PROVIDER>_<SERVICE>_API_KEY
    # 示例：channel="cx专用" 时可设为 "MONITOR_88CODE_CX_CX_DEDICATED_API_KEY"
    headers:
      Authorization: "Bearer {{API_KEY}}"
      Content-Type: "application/json"
    body: |
      {
        "model": "claude-3-opus",
        "messages": [{"role": "user", "content": "hi"}],
        "max_tokens": 1
      }
    # 可选：per-monitor 重试配置（覆盖全局和 by_service 配置）
    # retry: 1                    # 额外重试 1 次（优先级：monitor > by_service > global）
    # retry_base_delay: "150ms"   # 退避基准间隔
    # retry_max_delay: "1s"       # 退避最大间隔
    # retry_jitter: 0             # 显式关闭抖动

  - provider: "88code"
    service: "cx"
    category: "public"           # 公益站
    sponsor: "社区赞助"          # 由社区赞助者提供
    channel: "standard-channel"
    url: "https://api.88code.com/v1/chat/completions"
    method: "POST"
    api_key: "sk-xxxxxxxx"
    headers:
      Authorization: "Bearer {{API_KEY}}"
      Content-Type: "application/json"
    body: |
      {
        "model": "gpt-4",
        "messages": [{"role": "user", "content": "hi"}],
        "max_tokens": 1
      }
    # 可选：要求响应体包含该关键字才视为成功（语义校验）
    success_contains: "hi"

  # --- DuckCoding (演示不同的 Header 格式) ---
  - provider: "duckcoding"
    service: "cc"
    category: "commercial"
    sponsor: "duckcoding官方"
    channel: "vip-channel"
    url: "https://api.duckcoding.com/v1/messages"
    method: "POST"
    api_key: "sk-duck-xxxx"
    # 监测项级别徽标配置（可选）
    # 会与 badge_providers 中的 provider 级别徽标合并，并按 weight 排序
    badges:
      - "stream_support"  # 简写形式
    headers:
      x-api-key: "{{API_KEY}}"
      anthropic-version: "2023-06-01"
      content-type: "application/json"
    body: |
      {
        "model": "claude-3-sonnet",
        "max_tokens": 1,
        "messages": [{"role": "user", "content": "hi"}]
      }

  # --- 引用 data/ 目录下 JSON 的示例 ---
  - provider: "demo"
    service: "codex"
    category: "public"
    sponsor: "示例数据"
    channel: "test-channel"
    url: "https://88code.org/openai/v1/responses"
    method: "POST"
    api_key: "sk-demo"
    headers:
      Authorization: "Bearer {{API_KEY}}"
      Content-Type: "application/json"
    body: "!include data/cx_base.json"

  # --- 单个监测项下架示例 ---
  # - provider: "问题商家"
  #   service: "cc"
  #   category: "commercial"
  #   sponsor: "xxx"
  #   hidden: true                    # 临时下架（继续监测但不展示）
  #   hidden_reason: "该通道临时维护"  # 可选：下架原因
  #   url: "https://..."
  #   method: "POST"
  #   # ... 其他配置

  # --- 冷板监测项示例（仅展示历史，不探测）---
  # - provider: "归档商家"
  #   service: "cc"
  #   category: "commercial"
  #   sponsor: "xxx"
  #   board: "cold"                   # 移入冷板，停止监测但保留历史数据展示
  #   cold_reason: "该渠道长期不稳定，先归档节省探测资源"  # 可选：归档原因
  #   url: "https://..."
  #   method: "POST"
  #   # ... 其他配置
