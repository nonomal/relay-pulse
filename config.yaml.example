interval: "1m"       # 巡检间隔，可写成 "30s"、"1m"、"5m" 等
slow_latency: "5s"   # 慢请求阈值，超过则从绿降为黄

# ============================================
# 重试配置（全局默认值，模板和 monitor 可覆盖）
# ============================================
# 探测失败时自动重试，适用于网络不稳定场景
# 重试条件：所有 status=0 的错误（除超时外）
# 超时（context.DeadlineExceeded）不重试，因为已达总超时限制
# 优先级：monitor > template > global

# 全局重试次数（默认 0，不重试；表示"额外重试次数"，不含首次）
# retry: 0

# 退避基准间隔（默认 200ms）
# retry_base_delay: "200ms"

# 退避最大间隔（默认 2s）
# retry_max_delay: "2s"

# 抖动比例（0-1，默认 0.2；0 表示无抖动）
# retry_jitter: 0.2

# ============================================
# 并发控制与调度策略
# ============================================

# 最大并发探测数（可选，默认 10）
# - 不配置或 0: 使用默认值 10
# - -1: 无限制，自动扩容到监测项数量
# - >0: 硬上限，超过时监测项会排队等待执行
max_concurrency: 15

# 错峰调度（可选，默认 true）
stagger_probes: true

# ============================================
# API 性能优化
# ============================================

# 并发查询优化（可选，默认 false）
# ⚠️ 仅适用于 PostgreSQL，SQLite 使用单连接无并发收益
enable_concurrent_query: false
concurrent_query_limit: 10

# 可用率中黄色状态的权重（0-1，默认 0.7）
degraded_weight: 0.7

# ============================================
# 赞助商置顶配置
# ============================================
sponsor_pin:
  enabled: true
  max_pinned: 3
  min_uptime: 95.0
  min_level: "beacon"

# ============================================
# 热板/冷板功能配置
# ============================================
boards:
  enabled: false
  auto_move:
    enabled: false
    threshold_cold: 10.0      # 低于该值自动移入冷板（sticky，需人工 auto_cold_exempt 解除）
    threshold_down: 50.0      # hot → secondary
    threshold_up: 55.0        # secondary → hot
    min_probes: 10
    check_interval: "30m"

# ============================================
# 自助测试功能配置
# ============================================
selftest:
  enabled: false
  max_concurrent: 10
  max_queue_size: 50
  job_timeout: "30s"
  result_ttl: "2m"
  rate_limit_per_minute: 10

# ============================================
# 事件通知配置（状态订阅）
# ============================================
events:
  enabled: false
  down_threshold: 2
  up_threshold: 1
  api_token: ""

# ============================================
# 存储配置（支持 SQLite 和 PostgreSQL）
# ============================================
storage:
  type: "sqlite"
  sqlite:
    path: "monitor.db"
  # postgres:
  #   host: "localhost"
  #   port: 5432
  #   user: "monitor"
  #   password: "monitor_password"
  #   database: "llm_monitor"
  #   sslmode: "disable"

# ============================================
# 标签系统配置
# ============================================
enable_annotations: true

# key_type 字段：控制 API Key 来源标签（系统自动派生）
#   - 空值或 "official"（默认）：自动标注"官方 API"
#   - "user"：自动标注"用户 Key"
# 无需在 annotation_rules 中手动配置，只需在 monitor 上设置 key_type 即可

# annotation_rules 仍可用于高级自定义标签（覆盖或移除系统派生标签）
# annotation_rules:
#   - match:
#       provider: "example"
#     remove: ["key_type"]  # 移除系统派生的 key_type 标签
#     add:
#       - id: "key_type"
#         family: "positive"
#         label: "平台托管 Key"
#         icon: "shield-check"
#         priority: 90

# ============================================
# 监测任务配置
# ============================================
# 新的模板化配置方式：
#   - template: 引用 templates/ 目录下的 JSON 模板文件（包含 url/method/headers/body/response/model/request_model）
#   - base_url: 服务商基础地址，模板通过 {{BASE_URL}} 注入
#   - model: 展示名称（由模板预设，也可手动覆盖）
#   - request_model: 实际请求的模型 ID（由模板预设，请求时优先于 model，通过 {{MODEL}} 注入）
#   - api_key: API 密钥，模板通过 {{API_KEY}} 注入
#
# 模板支持的占位符：
#   {{BASE_URL}}          - 服务商基础地址（来自 base_url）
#   {{API_KEY}}           - API 密钥（来自 api_key / env）
#   {{MODEL}}             - 模型名称（来自 model）
#   {{USER_ID}}           - 通道级用户标识（按 user_id_refresh_minutes 刷新）
#   {{USER_ID_HASH}}      - USER_ID 短哈希
#   {{RAND_UUID}}         - 随机 UUID v4（每次探测生成）
#   {{PROMPT}}            - 动态算术题（防缓存模板用）
#   {{EXPECTED_ANSWER}}   - 预期答案（与 PROMPT 同步）
#
# 可用模板（templates/ 目录）：
#   CC: cc-haiku-arith, cc-sonnet-arith, cc-opus-arith
#   CX: cx-gpt-arith, cx-codex-arith
#   GM: gm-flash-arith, gm-pro-arith

monitors:
  # --- Claude Code (CC) 示例 ---
  - provider: "88code"
    provider_slug: "88code"
    provider_url: "https://88code.com"
    service: "cc"
    category: "commercial"
    sponsor: "团队自有"
    sponsor_level: "beacon"
    channel: "vip3"
    base_url: "https://api.88code.com"
    template: "cc-haiku-arith"
    api_key: "sk-xxxxxxxx"
    # model 和 request_model 由模板预设，无需手动指定

  # --- 同服务商多模型（父子继承）---
  # 子通道通过 parent 继承 base_url, api_key 等公共配置
  # 每个子通道指定不同的 template 来选择模型
  - provider: "88code"
    service: "cc"
    channel: "vip3"
    base_url: "https://api.88code.com"
    template: "cc-haiku-arith"
    api_key: "sk-xxxxxxxx"
    category: "commercial"
    sponsor: "团队自有"
  # - template: "cc-sonnet-arith"  # 子通道示例（取消注释使用）
  #   parent: "88code/cc/vip3"     # 继承父通道配置

  # --- Codex (CX) 示例 ---
  - provider: "88code"
    service: "cx"
    category: "commercial"
    sponsor: "团队自有"
    channel: "standard"
    base_url: "https://api.88code.com"
    template: "cx-codex-arith"
    api_key: "sk-xxxxxxxx"
    # model 和 request_model 由模板预设

  # --- 用户 Key 通道示例 ---
  # key_type: user 标记该通道使用用户自有的 API Key
  # - provider: "example"
  #   service: "cc"
  #   category: "commercial"
  #   channel: "user-key"
  #   key_type: "user"      # 自动标注"用户 Key"标签
  #   template: "cc-haiku-arith"
  #   base_url: "https://api.example.com"
  #   api_key: "sk-user-key"

  # --- Gemini (GM) 示例 ---
  # GM 模板的 URL 包含 {{MODEL}}，API Key 在 header 中：
  # {{BASE_URL}}/v1beta/models/{{MODEL}}:generateContent
  - provider: "google"
    service: "gm"
    category: "public"
    sponsor: "官方直连"
    channel: "direct"
    base_url: "https://generativelanguage.googleapis.com"
    template: "gm-flash-arith"
    api_key: "AIza..."
    # model 和 request_model 由模板预设

  # --- 防缓存模式（算术题）---
  # 所有模板均使用 arith 模式，每次探测生成随机算术题
  # 防止服务商缓存固定提示词的响应
  # model 和 request_model 由模板预设，无需手动指定

  # --- 高级配置：自定义 headers 覆盖模板 ---
  # 模板提供基础 headers，config 中的 headers 会覆盖同名 key
  # - provider: "custom"
  #   service: "cc"
  #   category: "commercial"
  #   sponsor: "自定义"
  #   channel: "special"
  #   base_url: "https://custom-api.example.com"
  #   template: "cc-haiku-arith"
  #   api_key: "sk-custom"
  #   headers:
  #     X-Custom-Header: "custom-value"  # 新增 header
  #     User-Agent: "custom-agent/1.0"   # 覆盖模板中的 User-Agent

  # --- user_id 刷新配置（可选）---
  # 默认使用确定性固定值（基于通道标识的 SHA-256）
  # 设置 user_id_refresh_minutes > 0 可启用定期轮换
  # - provider: "88code"
  #   service: "cc"
  #   channel: "rotating-uid"
  #   base_url: "https://api.88code.com"
  #   template: "cc-haiku-arith"
  #   api_key: "sk-xxx"
  #   user_id_refresh_minutes: 30  # 每 30 分钟更换 user_id

  # --- 冷板示例 ---
  # - provider: "归档商家"
  #   service: "cc"
  #   category: "commercial"
  #   sponsor: "xxx"
  #   board: "cold"
  #   cold_reason: "该渠道长期不稳定，先归档节省探测资源"
  #   base_url: "https://api.example.com"
  #   template: "cc-haiku-arith"
  #   api_key: "sk-xxx"

  # --- 自动冷板恢复示例 ---
  # 当 auto_move 自动将通道移入冷板后，需人工设置 auto_cold_exempt 解除：
  # - provider: "恢复商家"
  #   service: "cc"
  #   channel: "vip"
  #   category: "commercial"
  #   auto_cold_exempt: true   # 清除 runtime 自动冷板，保持为 true 期间不再自动冷板
  #   base_url: "https://api.example.com"
  #   template: "cc-haiku-arith"
  #   api_key: "sk-xxx"
