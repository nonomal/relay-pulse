interval: "1m"       # 巡检间隔，可写成 "30s"、"1m"、"5m" 等
slow_latency: "5s"   # 慢请求阈值，超过则从绿降为黄

# 按服务类型覆盖慢请求阈值（可选）
# key 不区分大小写，未配置的服务使用全局 slow_latency
# slow_latency_by_service:
#   cc: "15s"    # Claude Code 对速度要求较低
#   cx: "10s"    # Codex
#   gm: "3s"     # 模型 API 要求更快

# ============================================
# 重试配置
# ============================================
# 探测失败时自动重试，适用于网络不稳定场景
# 重试条件：所有 status=0 的错误（除超时外）
# 超时（context.DeadlineExceeded）不重试，因为已达总超时限制

# 全局重试次数（默认 0，不重试；表示"额外重试次数"，不含首次）
# retry: 0

# 退避基准间隔（默认 200ms）
# retry_base_delay: "200ms"

# 退避最大间隔（默认 2s）
# retry_max_delay: "2s"

# 抖动比例（0-1，默认 0.2；0 表示无抖动）
# retry_jitter: 0.2

# 按服务类型覆盖重试配置（可选）
# retry_by_service:
#   cc: 2        # Claude Code 服务额外重试 2 次
#   gm: 1        # Gemini 服务额外重试 1 次

# retry_base_delay_by_service:
#   cc: "300ms"

# retry_max_delay_by_service:
#   cc: "3s"

# retry_jitter_by_service:
#   cc: 0.1

# ============================================
# 并发控制与调度策略
# ============================================

# 最大并发探测数（可选，默认 10）
# - 不配置或 0: 使用默认值 10
# - -1: 无限制，自动扩容到监测项数量
# - >0: 硬上限，超过时监测项会排队等待执行
max_concurrency: 15

# 错峰调度（可选，默认 true）
stagger_probes: true

# ============================================
# API 性能优化
# ============================================

# 并发查询优化（可选，默认 false）
# ⚠️ 仅适用于 PostgreSQL，SQLite 使用单连接无并发收益
enable_concurrent_query: false
concurrent_query_limit: 10

# 可用率中黄色状态的权重（0-1，默认 0.7）
degraded_weight: 0.7

# ============================================
# 赞助商置顶配置
# ============================================
sponsor_pin:
  enabled: true
  max_pinned: 3
  min_uptime: 95.0
  min_level: "beacon"

# ============================================
# 热板/冷板功能配置
# ============================================
boards:
  enabled: false

# ============================================
# 自助测试功能配置
# ============================================
selftest:
  enabled: false
  max_concurrent: 10
  max_queue_size: 50
  job_timeout: "30s"
  result_ttl: "2m"
  rate_limit_per_minute: 10

# ============================================
# 事件通知配置（状态订阅）
# ============================================
events:
  enabled: false
  down_threshold: 2
  up_threshold: 1
  api_token: ""

# ============================================
# 存储配置（支持 SQLite 和 PostgreSQL）
# ============================================
storage:
  type: "sqlite"
  sqlite:
    path: "monitor.db"
  # postgres:
  #   host: "localhost"
  #   port: 5432
  #   user: "monitor"
  #   password: "monitor_password"
  #   database: "llm_monitor"
  #   sslmode: "disable"

# ============================================
# 通用徽标系统配置
# ============================================
enable_badges: true

badge_definitions:
  api_key_user:
    kind: "source"
    variant: "info"
    weight: 50
  api_key_official:
    kind: "source"
    variant: "success"
    weight: 80

badge_providers:
  - provider: "88code"
    badges:
      - "api_key_official"

# ============================================
# 监测任务配置
# ============================================
# 新的模板化配置方式：
#   - template: 引用 templates/ 目录下的 JSON 模板文件（包含 url/method/headers/body/response）
#   - base_url: 服务商基础地址，模板通过 {{BASE_URL}} 注入
#   - model: 模型名称，模板通过 {{MODEL}} 注入
#   - api_key: API 密钥，模板通过 {{API_KEY}} 注入
#
# 模板支持的占位符：
#   {{BASE_URL}}          - 服务商基础地址（来自 base_url）
#   {{API_KEY}}           - API 密钥（来自 api_key / env）
#   {{MODEL}}             - 模型名称（来自 model）
#   {{USER_ID}}           - 通道级用户标识（按 user_id_refresh_minutes 刷新）
#   {{USER_ID_HASH}}      - USER_ID 短哈希
#   {{RAND_UUID}}         - 随机 UUID v4（每次探测生成）
#   {{PROMPT}}            - 动态算术题（防缓存模板用）
#   {{EXPECTED_ANSWER}}   - 预期答案（与 PROMPT 同步）
#
# 可用模板（templates/ 目录）：
#   CC: cc-haiku-base, cc-haiku-tiny, cc-opus-tiny, cc-sonnet-tiny, cc-arith
#   CX: cx-codex-base, cx-gpt52-base, cx-codexmax-base, cx-codexmini-base, cx-arith
#   GM: gm-base, gm-thinking, gm-arith

monitors:
  # --- Claude Code (CC) 示例 ---
  - provider: "88code"
    provider_slug: "88code"
    provider_url: "https://88code.com"
    service: "cc"
    category: "commercial"
    sponsor: "团队自有"
    sponsor_level: "beacon"
    channel: "vip3"
    base_url: "https://api.88code.com"
    template: "cc-haiku-base"
    api_key: "sk-xxxxxxxx"
    model: "claude-haiku-4-5-20251001"

  # --- 同服务商多模型（父子继承）---
  # 子通道通过 parent 继承 base_url, template, api_key 等公共配置
  # 只需指定不同的 model 和 channel
  - provider: "88code"
    service: "cc"
    channel: "vip3"
    base_url: "https://api.88code.com"
    template: "cc-haiku-base"
    api_key: "sk-xxxxxxxx"
    model: "claude-haiku-4-5-20251001"
    category: "commercial"
    sponsor: "团队自有"
  # - provider: "88code"           # 子通道示例（取消注释使用）
  #   service: "cc"
  #   channel: "vip3"
  #   model: "claude-sonnet-4-5-20250929"
  #   parent: "88code/cc/vip3"     # 继承父通道配置

  # --- Codex (CX) 示例 ---
  - provider: "88code"
    service: "cx"
    category: "commercial"
    sponsor: "团队自有"
    channel: "standard"
    base_url: "https://api.88code.com"
    template: "cx-codex-base"
    api_key: "sk-xxxxxxxx"
    model: "gpt-5-codex"

  # --- Gemini (GM) 示例 ---
  # GM 模板的 URL 包含 {{MODEL}} 和 {{API_KEY}}：
  # {{BASE_URL}}/v1beta/models/{{MODEL}}:streamGenerateContent?key={{API_KEY}}
  - provider: "google"
    service: "gm"
    category: "public"
    sponsor: "官方直连"
    channel: "direct"
    base_url: "https://generativelanguage.googleapis.com"
    template: "gm-base"
    api_key: "AIza..."
    model: "gemini-2.0-flash"

  # --- 防缓存模式（算术题）---
  # 使用 arith 模板，每次探测生成随机算术题
  # 防止服务商缓存固定提示词的响应
  # - provider: "88code"
  #   service: "cc"
  #   category: "commercial"
  #   sponsor: "团队自有"
  #   channel: "vip3-arith"
  #   base_url: "https://api.88code.com"
  #   template: "cc-arith"
  #   api_key: "sk-xxxxxxxx"
  #   model: "claude-haiku-4-5-20251001"

  # --- 高级配置：自定义 headers 覆盖模板 ---
  # 模板提供基础 headers，config 中的 headers 会覆盖同名 key
  # - provider: "custom"
  #   service: "cc"
  #   category: "commercial"
  #   sponsor: "自定义"
  #   channel: "special"
  #   base_url: "https://custom-api.example.com"
  #   template: "cc-haiku-base"
  #   api_key: "sk-custom"
  #   model: "claude-haiku-4-5-20251001"
  #   headers:
  #     X-Custom-Header: "custom-value"  # 新增 header
  #     User-Agent: "custom-agent/1.0"   # 覆盖模板中的 User-Agent

  # --- user_id 刷新配置（可选）---
  # 默认使用确定性固定值（基于通道标识的 SHA-256）
  # 设置 user_id_refresh_minutes > 0 可启用定期轮换
  # - provider: "88code"
  #   service: "cc"
  #   channel: "rotating-uid"
  #   base_url: "https://api.88code.com"
  #   template: "cc-haiku-base"
  #   api_key: "sk-xxx"
  #   model: "claude-haiku-4-5-20251001"
  #   user_id_refresh_minutes: 30  # 每 30 分钟更换 user_id

  # --- 冷板示例 ---
  # - provider: "归档商家"
  #   service: "cc"
  #   category: "commercial"
  #   sponsor: "xxx"
  #   board: "cold"
  #   cold_reason: "该渠道长期不稳定，先归档节省探测资源"
  #   base_url: "https://api.example.com"
  #   template: "cc-haiku-base"
  #   api_key: "sk-xxx"
  #   model: "claude-haiku-4-5-20251001"
