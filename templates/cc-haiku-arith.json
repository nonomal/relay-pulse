{
	"model": "Haiku",
	"request_model": "claude-haiku-4-5-20251001",
	"url": "{{BASE_URL}}/v1/messages",
	"method": "POST",
	"headers": {
		"Authorization": "Bearer {{API_KEY}}",
		"Content-Type": "application/json",
		"Anthropic-Version": "2023-06-01"
	},
	"body": {
		"model": "{{MODEL}}",
		"max_tokens": 10,
		"stream": false,
		"messages": [{
			"role": "user",
			"content": "{{PROMPT}}"
		}]
	},
	"response": {
		"success_contains": "{{EXPECTED_ANSWER}}",
		"slow_latency": "5s",
		"timeout": "10s"
	}
}
