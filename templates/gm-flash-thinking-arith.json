{
	"model": "Flash Thinking",
	"request_model": "gemini-2.5-flash-thinking",
	"url": "{{BASE_URL}}/v1beta/models/{{MODEL}}:generateContent",
	"method": "POST",
	"headers": {
		"Content-Type": "application/json",
		"x-goog-api-key": "{{API_KEY}}",
		"User-Agent": "GeminiCLI/1.0"
	},
	"body": {
		"contents": [{
			"role": "user",
			"parts": [{
				"text": "{{PROMPT}}"
			}]
		}],
		"generationConfig": {
			"temperature": 0,
			"maxOutputTokens": 10,
			"thinkingConfig": { "thinkingBudget": 0 }
		}
	},
	"response": {
		"success_contains": "{{EXPECTED_ANSWER}}"
	},
	"probe": {
		"slow_latency": "4s",
		"timeout": "10s",
		"retry": 0
	}
}
