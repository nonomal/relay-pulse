{
	"model": "Sonnet",
	"request_model": "claude-sonnet-4-5-20250929",
	"url": "{{BASE_URL}}/v1/messages",
	"method": "POST",
	"headers": {
		"Authorization": "Bearer {{API_KEY}}",
		"Content-Type": "application/json",
		"Anthropic-Version": "2023-06-01"
	},
	"body": {
		"model": "{{MODEL}}",
		"max_tokens": 10,
		"stream": false,
		"messages": [{
			"role": "user",
			"content": "{{PROMPT}}"
		}]
	},
	"response": {
		"success_contains": "{{EXPECTED_ANSWER}}"
	},
	"probe": {
		"slow_latency": "4s",
		"timeout": "10s",
		"retry": 0
	}
}
