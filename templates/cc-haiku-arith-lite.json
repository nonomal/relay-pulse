{
	"model": "Haiku",
	"request_model": "claude-haiku-4-5-20251001",
	"url": "{{BASE_URL}}/v1/messages",
	"method": "POST",
	"headers": {
		"Authorization": "Bearer {{API_KEY}}",
		"Content-Type": "application/json",
		"Anthropic-Version": "2023-06-01",
		"User-Agent": "claude-cli/2.1.7 (external, cli)"
	},
	"body": {
		"model": "{{MODEL}}",
		"max_tokens": 20,
		"stream": true,
		"messages": [{
			"role": "user",
			"content": "{{PROMPT}}"
		}]
	},
	"response": {
		"success_contains": "{{EXPECTED_ANSWER}}"
	},
	"probe": {
		"slow_latency": "4s",
		"timeout": "10s",
		"retry": 0
	}
}
