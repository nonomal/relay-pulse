# ============================================
# Relay Pulse 环境变量配置
# ============================================
# 使用说明:
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填入真实的 API 密钥
# 3. .env 文件已自动加入 .gitignore，不会被提交
#
# Docker:   docker compose --env-file .env up -d
# Systemd:  EnvironmentFile=/etc/relay-pulse.env
# ============================================

# 时区设置
TZ=Asia/Shanghai

# Gin 运行模式（生产环境建议 release）
# GIN_MODE=release

# ============================================
# 存储配置
# ============================================
# 存储类型：sqlite（默认）或 postgres
# MONITOR_STORAGE_TYPE=sqlite

# SQLite 配置
# MONITOR_SQLITE_PATH=monitor.db

# PostgreSQL 配置（详见 .env.pg.example）
# MONITOR_POSTGRES_HOST=localhost
# MONITOR_POSTGRES_PORT=5432
# MONITOR_POSTGRES_USER=monitor
# MONITOR_POSTGRES_PASSWORD=your_secure_password
# MONITOR_POSTGRES_DATABASE=llm_monitor
# MONITOR_POSTGRES_SSLMODE=require

# ============================================
# API 密钥配置
# ============================================
# 格式: MONITOR_<PROVIDER>_<SERVICE>_API_KEY
# 注意: PROVIDER 和 SERVICE 需要全大写，破折号(-) 替换为下划线(_)

# 88code 服务
MONITOR_88CODE_CC_API_KEY=sk-your-88code-cc-key
MONITOR_88CODE_CX_API_KEY=sk-your-88code-cx-key

# DuckCoding 服务
MONITOR_DUCKCODING_CC_API_KEY=sk-your-duckcoding-key

# 其他服务商示例
# MONITOR_PROVIDER_SERVICE_API_KEY=sk-your-key

# ============================================
# CORS 配置（可选）
# ============================================
# 额外允许的 CORS 来源（逗号分隔，仅开发环境使用）
# MONITOR_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
