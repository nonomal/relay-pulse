{
	"url": "{{BASE_URL}}/v1/messages",
	"method": "POST",
	"headers": {
		"Authorization": "Bearer {{API_KEY}}",
		"Content-Type": "application/json",
		"User-Agent": "claude-cli/2.0.45 (external, cli)",
		"Anthropic-Beta": "interleaved-thinking-2025-05-14,context-management-2025-06-27,tool-examples-2025-10-29",
		"Anthropic-Version": "2023-06-01",
		"X-App": "cli"
	},
	"body": {
		"model": "{{MODEL}}",
		"messages": [{
			"role": "user",
			"content": [{
				"type": "text",
				"text": "ping"
			}]
		}, {
			"role": "assistant",
			"content": [{
				"type": "text",
				"text": "{"
			}]
		}],
		"system": [{
			"type": "text",
			"text": "Reply with JSON: {\"isNewTopic\": true, \"title\": \"test\"}"
		}],
		"tools": [],
		"metadata": {
			"user_id": "{{USER_ID}}"
		},
		"max_tokens": 100,
		"stream": false
	},
	"response": {
		"success_contains": "isNewTopic",
		"slow_latency": "5s",
		"timeout": "10s"
	}
}
